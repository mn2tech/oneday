# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# Required for shared guest messages, poll, and RSVPs (see supabase-setup.sql: event_messages, event_poll_votes, event_rsvps).
# Without the service role, those APIs return 503 and the event page falls back to local-only (browser storage) behavior.

# Stripe
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...

# Anthropic
ANTHROPIC_API_KEY=sk-ant-...
# Optional — model id (default: claude-sonnet-4-6). Set if your API returns model errors.
# ANTHROPIC_MODEL=claude-sonnet-4-20250514

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# AWS S3 — shared event photos (everyone with the link sees the same images)
# Create a bucket; add a CORS rule allowing PUT + GET from your site origin (e.g. https://getoneday.com).
# Optional: set AWS_S3_PUBLIC_BASE_URL to a CloudFront URL if you serve objects publicly from CDN.
# Otherwise the app uses presigned GET URLs (private bucket is OK).
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=your-bucket-name
# AWS_S3_PUBLIC_BASE_URL=https://your-cdn.example.com
