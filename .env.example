# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# Required for shared guest messages, poll, and RSVPs (see supabase-setup.sql: event_messages, event_poll_votes, event_rsvps).
# Without the service role, those APIs return 503 and the event page falls back to local-only (browser storage) behavior.

# Stripe
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_SECRET_KEY=sk_live_...
# Optional local-only escape hatch. Keep false/unset in production.
# ALLOW_DEV_TEST_PAYMENTS=true

# Anthropic
ANTHROPIC_API_KEY=sk-ant-...
# Optional — model id (default: claude-sonnet-4-6). Set if your API returns model errors.
# ANTHROPIC_MODEL=claude-sonnet-4-20250514

# App (used in confirmation emails and event links — must be your real site URL in production)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Resend — “your event is live” email with the /e/… link (optional locally; required in production if you want email)
# Get an API key at https://resend.com — verify your sending domain and set RESEND_FROM to match (e.g. OneDay <noreply@yourdomain.com>)
# RESEND_API_KEY=re_...
# RESEND_FROM=OneDay <noreply@getoneday.com>
# Host notifications — emails the event host when guests RSVP, post messages, or add photos.
# Set false/off/0 to disable.
# HOST_EMAIL_NOTIFICATIONS=true

# Guest device push notifications (opt-in on event page; no guest email required)
# Generate with: npx web-push generate-vapid-keys
# WEB_PUSH_SUBJECT=mailto:hello@getoneday.com
# WEB_PUSH_VAPID_PUBLIC_KEY=
# WEB_PUSH_VAPID_PRIVATE_KEY=

# Troubleshooting production
# - Shared messages / poll / RSVP: require SUPABASE_SERVICE_ROLE_KEY on the SERVER (Vercel → Settings → Environment Variables).
#   Only NEXT_PUBLIC_* vars are not enough. Photos use AWS env vars separately, so S3 can work while sharing does not.
# - Check: GET https://your-domain.com/api/health/cloud → sharedInteractionsReady should be true.
# - Email: RESEND_API_KEY must be set; same endpoint shows emailLikelyConfigured.
# - Optional: DEPLOYMENT_HEALTH_SECRET=random → GET /api/health/deployment?secret=random for a full boolean checklist.
# - Stripe checkout issues: same secret → GET /api/stripe-health?secret=random — verifies sk_* with Stripe and flags live/test mismatch vs pk_*.

# AWS S3 — shared event photos (everyone with the link sees the same images)
# Create a bucket; add a CORS rule allowing PUT + GET from your site origin (e.g. https://getoneday.com).
# Optional: set AWS_S3_PUBLIC_BASE_URL to a CloudFront URL if you serve objects publicly from CDN.
# Otherwise the app uses presigned GET URLs (private bucket is OK).
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=your-bucket-name
# AWS_S3_PUBLIC_BASE_URL=https://your-cdn.example.com
